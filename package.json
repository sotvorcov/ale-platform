{
  "name": "ale-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Foundation scaffolding for the ALE platform.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:site": "node --import tsx scripts/build-site.mjs && node scripts/build-slice.mjs",
    "start": "node dist/index.js",
    "dev": "node --import tsx --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import tsx --test src/index.test.ts src/slice/stub.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
